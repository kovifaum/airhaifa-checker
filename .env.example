# ============================================================
#  SkyWatch Flight Tracker — Environment Variables
#  Copy to .env and fill in your details
# ============================================================

# --- EMAIL (Gmail) ---
# Use your Gmail address + App Password
# Generate App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=your.email@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx

# --- 2CAPTCHA (for auto-booking) ---
# Get your API key from https://2captcha.com
TWOCAPTCHA_KEY=your_2captcha_api_key

# --- Check interval (milliseconds) ---
# Default: 30000 (30 seconds)
CHECK_INTERVAL_MS=30000

# --- Server ---
PORT=3000

# --- Puppeteer (for Docker/Render) ---
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
