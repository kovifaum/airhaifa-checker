# ============================================================
# Air Haifa Checker — Credentials Template
# Copy this file to .env and fill in your details
# ============================================================

# --- EMAIL (Gmail) ---
# Use your Gmail address
GMAIL_USER=your.email@gmail.com
# Use an App Password (NOT your normal Gmail password)
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled)
GMAIL_PASS=xxxx xxxx xxxx xxxx

# --- SMS (Twilio) ---
# Free trial available at https://www.twilio.com
# Get these from your Twilio Console dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Your Twilio phone number (include country code, e.g. +12025551234)
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# --- Server ---
PORT=3000
